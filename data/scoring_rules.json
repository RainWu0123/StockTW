{
  "version": "2026-06-23-fundamental-only",
  "description": "基本面選股系統 — 參考《別再看股價了》理念：只看 ROE/營收成長/EPS成長/PE，砍掉所有價格噪聲",
  "philosophy": "股價是結果，不是原因。好公司會自己反映在財務數據上。",
  "weights": {
    "roe": 50,
    "revenueGrowth": 25,
    "earningsGrowth": 15,
    "valuation": 10
  },
  "roe_tiers": [
    {"threshold": 0.20, "score": 50},
    {"threshold": 0.15, "score": 40},
    {"threshold": 0.10, "score": 30},
    {"threshold": 0.05, "score": 20},
    {"threshold": 0.00, "score": 10},
    {"threshold": -9.99, "score": 0}
  ],
  "revenue_growth_tiers": [
    {"threshold": 0.50, "score": 25},
    {"threshold": 0.30, "score": 22},
    {"threshold": 0.20, "score": 20},
    {"threshold": 0.10, "score": 15},
    {"threshold": 0.05, "score": 10},
    {"threshold": 0.00, "score": 8},
    {"threshold": -9.99, "score": 0}
  ],
  "earnings_growth_tiers": [
    {"threshold": 0.30, "score": 15},
    {"threshold": 0.10, "score": 12},
    {"threshold": 0.00, "score": 8},
    {"threshold": -9.99, "score": 0}
  ],
  "valuation_tiers": [
    {"threshold": 0, "threshold_type": "lt", "pe": 15, "score": 10},
    {"threshold": 0, "threshold_type": "lt", "pe": 25, "score": 8},
    {"threshold": 0, "threshold_type": "lt", "pe": 35, "score": 5},
    {"threshold": 0, "threshold_type": "lt", "pe": 50, "score": 2},
    {"threshold": 0, "threshold_type": "default", "score": 0}
  ],
  "data_requirements": {
    "roe": "優先採 yfinance info.returnOnEquity，若無資料則以 trailingPE + revenueGrowth 估算",
    "revenueGrowth": "data.json 內 revenueGrowth",
    "earningsGrowth": "data.json 內 earningsGrowth",
    "trailingPE": "data.json 內 trailingPE"
  },
  "output": "單一綜合分數 0-100，按分數排名。不輸出 tier。"
}
